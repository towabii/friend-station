// =====================
// Socket.io (WebRTC・チャット等)
// =====================
io.on('connection', socket => {
  const token = socket.handshake.auth?.token;
  if (!token || adminTokens.has(token)) { socket.isAdmin = true; return; }
  
  const pendingUser = getUserByPendingToken(token), authUser = getUserByToken(token);
  if (pendingUser) { socket.pendingUser = pendingUser; pendingSockets.set(token, socket); return; }
  if (!authUser || authUser.status !== 'approved' || authUser.is_banned === 1) { socket.emit('connect_error', new Error('NoToken')); socket.disconnect(true); return; }

  socket.userId = authUser.id;
  const userSet = userSockets.get(authUser.id) || new Set();
  userSet.add(socket);
  userSockets.set(authUser.id, userSet);
  broadcastUserStatus(authUser.id, true);

  socket.on('disconnecting', () => {
    socket.rooms.forEach(room => {
      if (room.startsWith('group_call_')) socket.to(room).emit('user_left_call', { session_id: room.replace('group_call_', ''), user_id: socket.userId });
      else if (room.startsWith('text_call_')) socket.to(room).emit('text_call_ended', { session_id: room.replace('text_call_', ''), user_id: socket.userId });
    });
  });

  socket.on('disconnect', () => {
    if (socket.userId) {
      const set = userSockets.get(socket.userId);
      if (set) { set.delete(socket); if (set.size === 0) userSockets.delete(socket.userId); }
      if (!userSockets.has(socket.userId)) broadcastUserStatus(socket.userId, false);
    }
    if (socket.pendingUser?.pendingToken) pendingSockets.delete(socket.pendingUser.pendingToken);
  });

  socket.on('check_online', uids => {
    if (!Array.isArray(uids)) return;
    const status = {}; uids.forEach(uid => status[uid] = userSockets.has(uid));
    socket.emit('online_status', status);
  });

  socket.on('join_room', roomId => { if (roomId) socket.join(roomId); });

  socket.on('send_message', async message => {
    if (!socket.userId) return;
    const room_id = safeString(message.room_id);
    if (!room_id) return;
    const msg = { msg_id: generateId(), room_id, user_id: socket.userId, user_name: authUser.nickname, content: safeString(message.content), type: safeString(message.type) || 'text', reply_to: message.reply_to || null, timestamp: now(), is_deleted: 0, is_read: false, read_by: [], reactions: '{}' };
    db.messages.push(msg);
    await saveDb();
    io.to(room_id).emit('receive_message', msg);
    emitToAdmin('admin_new_message', msg);
    const participants = room_id.startsWith('g_') ? db.groups.find(g => g.id === room_id)?.members || [] : room_id.split('_');
    participants.forEach(uid => { if (uid !== socket.userId) broadcastUnreadCounts(uid); });
  });

  socket.on('mark_read', async roomId => {
    if (!socket.userId || !roomId) return;
    const isGroup = roomId.startsWith('g_');
    const updates = [];
    if (isGroup) {
      db.messages.forEach(msg => {
        if (msg.room_id !== roomId || msg.user_id === socket.userId) return;
        const read_by = Array.isArray(msg.read_by) ? msg.read_by : [];
        if (!read_by.includes(socket.userId)) { read_by.push(socket.userId); msg.read_by = read_by; updates.push({ msg_id: msg.msg_id, read_count: read_by.length }); }
      });
      await saveDb();
      io.to(roomId).emit('messages_read_bulk', { roomId, updates });
    } else {
      db.messages.forEach(msg => { if (msg.room_id === roomId && msg.user_id !== socket.userId && !msg.is_read) msg.is_read = true; });
      await saveDb();
      io.to(roomId).emit('messages_read', { roomId });
    }
  });

  socket.on('add_reaction', async data => {
    if (!socket.userId) return;
    const message = db.messages.find(m => m.msg_id === safeString(data.msg_id));
    if (!message) return;
    let reactions = {}; try { reactions = JSON.parse(message.reactions || '{}'); } catch (e) { reactions = {}; }
    const emoji = safeString(data.emoji); reactions[emoji] = reactions[emoji] || [];
    if (!reactions[emoji].includes(socket.userId)) reactions[emoji].push(socket.userId);
    message.reactions = JSON.stringify(reactions);
    await saveDb();
    io.to(safeString(data.room_id)).emit('message_reaction_update', { msg_id: message.msg_id, reactions });
  });

  socket.on('typing', data => { if (socket.userId && data.room_id) socket.to(safeString(data.room_id)).emit('typing', { room_id: data.room_id, user_id: socket.userId, nickname: authUser.nickname, is_typing: !!data.is_typing }); });

  socket.on('call_user', data => {
    const targetSockets = userSockets.get(safeString(data.target_id));
    if (!targetSockets || targetSockets.size === 0) { socket.emit('call_error', { message: '相手がオフラインです' }); return; }
    targetSockets.forEach(s => s.emit('incoming_call', { caller_id: socket.userId, caller_name: authUser.nickname, icon_url: authUser.icon_url || '', video: !!data.video, session_id: safeString(data.session_id), room_id: safeString(data.room_id) }));
  });

  socket.on('answer_call', data => {
    const targetSockets = userSockets.get(safeString(data.target_id));
    if (targetSockets) targetSockets.forEach(s => s.emit(data.accept ? 'call_answered' : 'call_rejected', { session_id: safeString(data.session_id), caller_id: socket.userId, answerer_id: socket.userId, icon_url: authUser.icon_url || '', nickname: authUser.nickname, accept: !!data.accept }));
  });

  socket.on('join_group_call', data => {
    if (data.session_id) { socket.join(`group_call_${safeString(data.session_id)}`); socket.to(`group_call_${safeString(data.session_id)}`).emit('user_joined_call', { user_id: socket.userId, icon_url: authUser.icon_url || '', nickname: authUser.nickname }); }
  });

  socket.on('hang_up', data => {
    const ts = userSockets.get(safeString(data.target_id));
    if (ts) ts.forEach(s => s.emit('hang_up', { session_id: safeString(data.session_id), user_id: socket.userId }));
    if (data.room_id && data.session_id) {
      socket.to(`group_call_${safeString(data.session_id)}`).emit('user_left_call', { room_id: safeString(data.room_id), session_id: safeString(data.session_id), user_id: socket.userId });
      socket.leave(`group_call_${safeString(data.session_id)}`);
    }
  });

  ['webrtc_offer', 'webrtc_answer', 'webrtc_ice'].forEach(evt => {
    socket.on(evt, data => {
      const ts = userSockets.get(safeString(data.target_id));
      if (ts) ts.forEach(s => s.emit(evt, { ...data, sender_id: socket.userId, sender_icon: authUser.icon_url || '', sender_name: authUser.nickname }));
    });
  });

  socket.on('call_text', data => {
    const ts = userSockets.get(safeString(data.target_id));
    if (!ts || ts.size === 0) { socket.emit('call_error', { message: '相手がオフラインです' }); return; }
    ts.forEach(s => s.emit('incoming_text_call', { caller_id: socket.userId, caller_name: authUser.nickname, icon_url: authUser.icon_url || '' }));
  });

  socket.on('answer_text', data => {
    const target_id = safeString(data.target_id || data.caller_id), ts = userSockets.get(target_id), session_id = `tc_${Date.now()}`;
    if (ts) ts.forEach(s => s.emit(data.accept ? 'text_call_started' : 'text_call_rejected', { session_id, target_name: authUser.nickname }));
    if (data.accept) socket.emit('text_call_started', { session_id, target_name: safeString(data.caller_name) || '通話相手' });
  });

  socket.on('join_text_call', data => { if (data.session_id) socket.join(`text_call_${safeString(data.session_id)}`); });

  socket.on('text_call_sync', data => {
    const session_id = safeString(data.session_id);
    if (data.room_id) socket.to(`text_call_${session_id}`).emit('text_call_sync_receive', { user_id: socket.userId, user_name: authUser.nickname, text: safeString(data.text) });
    else {
      const ts = userSockets.get(safeString(data.target_id));
      if (ts) ts.forEach(s => s.emit('text_call_sync_receive', { user_id: socket.userId, user_name: authUser.nickname, text: safeString(data.text) }));
    }
  });

  socket.on('end_text_call', data => {
    const ts = userSockets.get(safeString(data.target_id));
    if (ts) ts.forEach(s => s.emit('text_call_ended', { user_id: socket.userId }));
    if (data.room_id && data.session_id) { socket.to(`text_call_${safeString(data.session_id)}`).emit('text_call_ended', { room_id: safeString(data.room_id), session_id: safeString(data.session_id), user_id: socket.userId }); socket.leave(`text_call_${safeString(data.session_id)}`); }
  });

  socket.on('media_status', data => {
    const payload = { user_id: socket.userId, video: !!data.video, audio: !!data.audio };
    if (data.room_id) socket.to(safeString(data.room_id)).emit('media_status_update', payload);
    else if (data.target_id) { const ts = userSockets.get(safeString(data.target_id)); if (ts) ts.forEach(s => s.emit('media_status_update', payload)); }
  });
});

initialize().then(() => {
  server.listen(PORT, '0.0.0.0', () => console.log(`Friend Station backend running on http://0.0.0.0:${PORT}${BACKEND_PATH}`));
}).catch(err => { console.error('Failed to initialize backend:', err); process.exit(1); });

async function initialize() {
  await fs.mkdir(UPLOAD_DIR, { recursive: true });
  await loadDb();
}