// 3. アプリケーション制御クラス
class StudyBoxApp {
    constructor() {
        this.progress = JSON.parse(localStorage.getItem('studybox_progress')) || {};
        this.currentGrade = "1";
        this.currentSubject = "";
        this.currentChapIdx = 0;
        this.currentSecIdx = 0;
        
        // タイマー変数
        this.timerInterval = null;
        this.timeLeft = 25 * 60; // 25分
        this.isTimerRunning = false;

        this.init();
    }

    init() {
        this.startClock();
        this.initMemo();
        this.renderSubjectCards();
        this.updateTotalScore();
        document.getElementById('daily-quote').textContent = quotes[Math.floor(Math.random() * quotes.length)];
        
        // ダークモード復元
        if(localStorage.getItem('studybox_dark') === 'true') {
            document.body.classList.add('dark-mode');
        }
    }

    // --- UI ナビゲーション ---
    showHome() {
        document.getElementById('view-home').classList.remove('hidden');
        document.getElementById('view-learn').classList.add('hidden');
        this.updateTotalScore();
    }

    renderSubjectCards() {
        this.currentGrade = document.getElementById('grade-selector').value;
        const grid = document.getElementById('subject-grid');
        grid.innerHTML = '';

        const subjects = Object.keys(baseData);
        subjects.forEach(subj => {
            // その教科のクリア数を計算
            let clearedCount = 0;
            let totalCount = 0;
            curriculumDB[this.currentGrade][subj].forEach((chap, cIdx) => {
                chap.sections.forEach((sec, sIdx) => {
                    totalCount++;
                    if(this.progress[\`\${this.currentGrade}_\${subj}_\${cIdx}_\${sIdx}\`]) clearedCount++;
                });
            });

            const card = document.createElement('div');
            card.className = 'subject-card';
            card.onclick = () => this.startLearning(subj);
            card.innerHTML = \`
                <div style="font-size: 2.5rem; margin-bottom: 10px;">\${this.getSubjectIcon(subj)}</div>
                <h3>\${baseData[subj].name}</h3>
                <div class="subject-badge">全 \${totalCount} 単元搭載</div>
                <div style="font-size: 0.8rem; margin-top: 10px; color: var(--secondary);">達成度: \${clearedCount} / \${totalCount}</div>
            \`;
            grid.appendChild(card);
        });
    }

    getSubjectIcon(subj) {
        const icons = { kokugo: '📕', suugaku: '📐', eigo: '🔤', rika: '🔬', shakai: '🌍' };
        return icons[subj] || '📚';
    }

    // --- 学習ロジック ---
    startLearning(subject) {
        this.currentSubject = subject;
        document.getElementById('view-home').classList.add('hidden');
        document.getElementById('view-learn').classList.remove('hidden');
        
        document.getElementById('learn-subject-title').textContent = \`\${baseData[subject].name} カリキュラム\`;
        
        this.renderCurriculumList();
        this.loadSection(0, 0);
    }

    renderCurriculumList() {
        const list = document.getElementById('curriculum-list');
        list.innerHTML = '';
        
        const chapters = curriculumDB[this.currentGrade][this.currentSubject];
        chapters.forEach((chap, cIdx) => {
            const chapTitle = document.createElement('div');
            chapTitle.style.fontWeight = 'bold';
            chapTitle.style.marginTop = '15px';
            chapTitle.style.marginBottom = '5px';
            chapTitle.textContent = chap.chapter;
            list.appendChild(chapTitle);

            chap.sections.forEach((sec, sIdx) => {
                const item = document.createElement('div');
                item.className = 'list-item';
                
                const isCleared = this.progress[\`\${this.currentGrade}_\${this.currentSubject}_\${cIdx}_\${sIdx}\`];
                item.textContent = (isCleared ? '✅ ' : '📄 ') + sec.title;
                
                if (cIdx === this.currentChapIdx && sIdx === this.currentSecIdx) {
                    item.classList.add('active');
                }
                
                item.onclick = () => this.loadSection(cIdx, sIdx);
                list.appendChild(item);
            });
        });
    }

    loadSection(cIdx, sIdx) {
        this.currentChapIdx = cIdx;
        this.currentSecIdx = sIdx;
        this.renderCurriculumList(); // リストのハイライト更新

        const data = curriculumDB[this.currentGrade][this.currentSubject][cIdx].sections[sIdx];
        
        // 講義内容
        document.getElementById('lecture-title').textContent = data.title;
        document.getElementById('lecture-content').textContent = data.content;

        // クイズリセット
        document.getElementById('quiz-question').textContent = data.quiz.question;
        const optionsDiv = document.getElementById('quiz-options');
        optionsDiv.innerHTML = '';
        document.getElementById('quiz-feedback').style.display = 'none';

        data.quiz.options.forEach((opt, idx) => {
            const btn = document.createElement('button');
            btn.className = 'btn-option';
            btn.textContent = opt;
            btn.onclick = () => this.checkAnswer(idx, btn, data.quiz);
            optionsDiv.appendChild(btn);
        });
    }

    checkAnswer(idx, btn, quizData) {
        const buttons = document.querySelectorAll('.btn-option');
        buttons.forEach(b => b.disabled = true); // 連打防止
        
        const feedback = document.getElementById('quiz-feedback');
        const status = document.getElementById('feedback-status');
        const text = document.getElementById('feedback-text');

        if (idx === quizData.answer) {
            btn.classList.add('correct');
            status.textContent = "🎉 正解！";
            status.style.color = "var(--secondary)";
            feedback.style.backgroundColor = "rgba(16, 185, 129, 0.1)";
            feedback.style.border = "1px solid var(--secondary)";
            
            // 進捗保存
            this.progress[\`\${this.currentGrade}_\${this.currentSubject}_\${this.currentChapIdx}_\${this.currentSecIdx}\`] = true;
            localStorage.setItem('studybox_progress', JSON.stringify(this.progress));
            
            this.fireConfetti();
        } else {
            btn.classList.add('incorrect');
            buttons[quizData.answer].classList.add('correct'); // 正解を表示
            status.textContent = "❌ 不正解...";
            status.style.color = "var(--danger)";
            feedback.style.backgroundColor = "rgba(239, 68, 68, 0.1)";
            feedback.style.border = "1px solid var(--danger)";
        }

        text.textContent = quizData.explanation;
        feedback.style.display = 'block';
        this.renderCurriculumList(); // サイドバーのチェックマーク更新
    }

    nextLesson() {
        const chapters = curriculumDB[this.currentGrade][this.currentSubject];
        const currentChap = chapters[this.currentChapIdx];

        if (this.currentSecIdx + 1 < currentChap.sections.length) {
            this.loadSection(this.currentChapIdx, this.currentSecIdx + 1);
        } else if (this.currentChapIdx + 1 < chapters.length) {
            this.loadSection(this.currentChapIdx + 1, 0);
            // 章が変わった時、サイドバーをスクロール
            document.querySelector('.curriculum-list').scrollTop = 0;
        } else {
            alert("圧倒的努力！この教科の全カリキュラムを読破しました！");
            this.showHome();
        }
    }

    updateTotalScore() {
        document.getElementById('total-score').textContent = Object.keys(this.progress).length;
    }

    resetProgress() {
        if(confirm('今までの学習進捗をすべてリセットしますか？この操作は取り消せません。')) {
            localStorage.removeItem('studybox_progress');
            this.progress = {};
            this.showHome();
            this.renderSubjectCards();
        }
    }

    // --- 各種ツール機能 ---
    toggleDarkMode() {
        document.body.classList.toggle('dark-mode');
        localStorage.setItem('studybox_dark', document.body.classList.contains('dark-mode'));
    }

    startClock() {
        setInterval(() => {
            const now = new Date();
            document.getElementById('real-clock').textContent = now.toLocaleTimeString('ja-JP');
        }, 1000);
    }

    // ポモドーロタイマー
    updateTimerDisplay() {
        const m = Math.floor(this.timeLeft / 60).toString().padStart(2, '0');
        const s = (this.timeLeft % 60).toString().padStart(2, '0');
        document.getElementById('study-timer').textContent = \`\${m}:\${s}\`;
    }

    toggleTimer() {
        const btn = document.getElementById('timer-btn');
        if (this.isTimerRunning) {
            clearInterval(this.timerInterval);
            btn.textContent = 'スタート';
            btn.style.background = 'var(--secondary)';
        } else {
            this.timerInterval = setInterval(() => {
                if (this.timeLeft > 0) {
                    this.timeLeft--;
                    this.updateTimerDisplay();
                } else {
                    clearInterval(this.timerInterval);
                    alert("25分の学習が終了しました！5分休憩しましょう。");
                    this.resetTimer();
                }
            }, 1000);
            btn.textContent = '一時停止';
            btn.style.background = 'var(--accent)';
        }
        this.isTimerRunning = !this.isTimerRunning;
    }

    resetTimer() {
        clearInterval(this.timerInterval);
        this.isTimerRunning = false;
        this.timeLeft = 25 * 60;
        this.updateTimerDisplay();
        document.getElementById('timer-btn').textContent = 'スタート';
        document.getElementById('timer-btn').style.background = 'var(--secondary)';
    }

    // 学習メモ
    initMemo() {
        const memoPad = document.getElementById('memo-pad');
        memoPad.value = localStorage.getItem('studybox_memo') || '';
        memoPad.addEventListener('input', () => {
            localStorage.setItem('studybox_memo', memoPad.value);
        });
    }

    // 演出：紙吹雪
    fireConfetti() {
        const colors = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6'];
        for (let i = 0; i < 30; i++) {
            const conf = document.createElement('div');
            conf.className = 'confetti';
            conf.style.left = Math.random() * 100 + 'vw';
            conf.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            conf.style.animationDuration = (Math.random() * 2 + 2) + 's';
            document.body.appendChild(conf);
            setTimeout(() => conf.remove(), 4000);
        }
    }
}

