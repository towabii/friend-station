            fullDb[grade][subj] = [];
            
            // ベースの手書きデータを投入
            fullDb[grade][subj].push({
                chapter: subjData.chapters[0].chap,
                sections: [{
                    title: subjData.chapters[0].sec,
                    content: \`【中\${grade} \${subjData.name}】\\n\` + subjData.chapters[0].content,
                    quiz: {
                        question: subjData.chapters[0].q,
                        options: subjData.chapters[0].o,
                        answer: subjData.chapters[0].a,
                        explanation: subjData.chapters[0].exp
                    }
                }]
            });

            // ★不足分（31個）のカリキュラムをプロシージャル（自動）生成して追加
            let currentChapterNum = 2;
            let currentSections = [];
            
            for (let i = 1; i <= 31; i++) {
                currentSections.push({
                    title: \`\${subjData.name} 応用トレーニング Sec.\${i}\`,
                    content: \`【自動生成カリキュラム】中\${grade} \${subjData.name} の応用トレーニング第\${i}項です。\\nここでは反復練習を通じて基礎力を圧倒的なレベルまで引き上げます。テキストをしっかり読み込み、クイズに挑戦してください。\`,
                    quiz: {
                        question: \`トレーニング問題 \${i}：この単元の学習を完了しましたか？\`,
                        options: ["はい、完全に理解しました", "いいえ、まだです", "少し不安です", "全くわかりません"],
                        answer: 0,
                        explanation: "素晴らしい！反復練習こそがStudyBOXの真髄です。この調子で進めましょう。"
                    }
                });

                // 5節ごとに新しい章にする
                if (i % 5 === 0 || i === 31) {
                    fullDb[grade][subj].push({
                        chapter: \`第\${currentChapterNum}章 \${subjData.name}特訓プログラム\`,
                        sections: [...currentSections]
                    });
                    currentChapterNum++;
                    currentSections = [];
                }
            }
        });
    }
    return fullDb;
}

