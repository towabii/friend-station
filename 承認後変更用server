    const token = generateToken(); user.token = token; db.sessions.push({ token, user_id: user.id, created_at: now() });
    if (pt && pendingSockets.has(pt)) { pendingSockets.get(pt).emit('registration_approved', { token, user: sanitizeUser(user) }); pendingSockets.delete(pt); }
